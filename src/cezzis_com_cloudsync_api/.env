# ==========================================================================|
# This is a template .env file. For local development puposes,              |  
# copy this file to .env.local and fill in the values.                      |  
# The app_settings.json file is configured to read from environment         |
# variables and uses the currently configured ENV variable to               |
# determine which .env file to load.  For local development this ENV        |
# var is set to 'local' in the launch.json and makefile.                    |
# --------------------------------------------------------------------------|
# (ex: .env.local)                                                          |
# ==========================================================================|
# --------------------------------------------------------------------------|
# Api Options                                                               |
# --------------------------------------------------------------------------|
ACCOUNTS_API_ALLOWED_ORIGINS=
APIM_HOST_KEY=
ALEMBIC_CONFIG=
# --------------------------------------------------------------------------|
# Auth0 management                                                          |
# --------------------------------------------------------------------------|
AUTH0_MANAGEMENT_DOMAIN=
AUTH0_MANAGEMENT_M2M_CLIENT_ID=
AUTH0_MANAGEMENT_M2M_CLIENT_SECRET=
AUTH0_DATABASE_CONNECTION_NAME=
# --------------------------------------------------------------------------|
# Blob Storage settings                                                     |
# --------------------------------------------------------------------------|
BLOB_STORAGE_CDN_HOSTNAME=
# --------------------------------------------------------------------------|
# OAuth2 settings                                                           |
# --------------------------------------------------------------------------|
OAUTH_DOMAIN=
OAUTH_AUDIENCE=
OAUTH_CLIENT_ID=
OAUTH_ISSUER=
OAUTH_PKCE=
# --------------------------------------------------------------------------|
# open telemetry / tracing settings                                         |
# --------------------------------------------------------------------------|
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=
OTEL_SERVICE_NAMESPACE=
OTEL_OTLP_AUTH_HEADER=
# --------------------------------------------------------------------------|
# postgres settings                                                         |
# --------------------------------------------------------------------------|
POSTGRES_HOSTNAME=
POSTGRES_PORT=
POSTGRES_DATABASE_NAME=
POSTGRES_USERNAME=
POSTGRES_PASSWORD=
# --------------------------------------------------------------------------|
# dapr settings                                                             |
# --------------------------------------------------------------------------|
DAPR_INIT_JOB_ENABLED=
DAPR_HOST=
# Needed for the dapr sdk to find the sidecar
DAPR_HTTP_ENDPOINT=
# Needed for the dapr sdk to find the sidecar
DAPR_GRPC_ENDPOINT=
DAPR_HTTP_PORT=
DAPR_GRPC_PORT=
# Token the app sends TO the Dapr sidecar (for outgoing calls to Dapr APIs)
DAPR_API_TOKEN=
# Token the Dapr sidecar sends TO the app (for incoming input binding calls)
APP_API_TOKEN=
# --------------------------------------------------------------------------|
# zoho email settings                                                       |
# --------------------------------------------------------------------------|
ZOHO_SMTP_HOST=
ZOHO_SMTP_PORT=
ZOHO_DEFAULT_SENDER_EMAIL=
ZOHO_DEFAULT_SENDER_APP_PASSWORD=