# ==========================================================================|
# This is a template .env file. For local development puposes,              |  
# copy this file to .env.local and fill in the values.                      |  
# The app_settings.json file is configured to read from environment         |
# variables and uses the currently configured ENV variable to               |
# determine which .env file to load.  For local development this ENV        |
# var is set to 'local' in the launch.json and makefile.                    |
# --------------------------------------------------------------------------|
# (ex: .env.local)                                                          |
# ==========================================================================|
# --------------------------------------------------------------------------|
# Api Options                                                               |
# --------------------------------------------------------------------------|
CLOUDSYNC_API_ALLOWED_ORIGINS=
CLOUDSYNC_API_COCKTAIL_UPDATE_SYNC_TOPIC=
CLOUDSYNC_API_COCKTAIL_UPDATE_SYNC_LABEL=
CLOUDSYNC_API_COCKTAIL_UPDATE_SYNC_DAPR_BINDING=
CLOUDSYNC_API_COCKTAIL_UPDATE_SYNC_DAPR_INPUT_BINDING=
CLOUDSYNC_API_COCKTAIL_UPDATE_SYNC_DAPR_DEADLETTER_PUBSUB=
CLOUDSYNC_API_COCKTAIL_UPDATE_SYNC_DAPR_DEADLETTER_LABEL=
CLOUDSYNC_API_COCKTAIL_UPDATE_SYNC_DAPR_DEADLETTER_TOPIC=
# --------------------------------------------------------------------------|
# OAuth2 settings                                                           |
# --------------------------------------------------------------------------|
OAUTH_DOMAIN=
OAUTH_AUDIENCE=
OAUTH_CLIENT_ID=
OAUTH_ISSUER=
OAUTH_PKCE=
# --------------------------------------------------------------------------|
# open telemetry / tracing settings                                         |
# --------------------------------------------------------------------------|
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=
OTEL_SERVICE_NAMESPACE=
OTEL_OTLP_AUTH_HEADER=
# --------------------------------------------------------------------------|
# dapr settings                                                             |
# --------------------------------------------------------------------------|
DAPR_HOST=
# Needed for the dapr sdk to find the sidecar
DAPR_HTTP_ENDPOINT=
# Needed for the dapr sdk to find the sidecar
DAPR_GRPC_ENDPOINT=
DAPR_HTTP_PORT=
DAPR_GRPC_PORT=
# Token the app sends TO the Dapr sidecar (for outgoing calls to Dapr APIs)
DAPR_API_TOKEN=
# Token the Dapr sidecar sends TO the app (for incoming input binding calls)
APP_API_TOKEN=
# --------------------------------------------------------------------------|
# kafka settings                                                            |
# --------------------------------------------------------------------------|
KAFKA_BOOTSTRAP_SERVERS=